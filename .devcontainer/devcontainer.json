{
  "name": "AI for Coding Workshop (R)",
  "image": "rocker/tidyverse:4.4.1",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  },
  "postCreateCommand": "Rscript -e 'install.packages(\"languageserver\", repos=\"https://cloud.r-project.org\")'",
  "forwardPorts": []
}
